# Base URL for your OpenAI-compatible proxy/provider
OPENAI_BASE_URL=https://route.example.com/v1

# API key for your proxy/provider
OPENAI_API_KEY=replace-me

# Optional explicit OpenRouter-compatible key.
# If omitted, the Docker image patch falls back to OPENAI_API_KEY.
OPENROUTER_API_KEY=replace-me

# Model used for memory compression
COMPRESSION_MODEL=deep/deepseek-default

# Local embeddings avoid external embedding APIs
EMBEDDING_PROVIDER=local

# Bearer token required by the REST API
AGENTMEMORY_SECRET=change-me

# Disable Agent SDK recursion
AGENTMEMORY_ALLOW_AGENT_SDK=false

# Compression and memory features
AGENTMEMORY_AUTO_COMPRESS=true
AGENTMEMORY_COMPRESS=true
AGENTMEMORY_SLOTS=true
AGENTMEMORY_REFLECT=true
AGENTMEMORY_INJECT_CONTEXT=true
GRAPH_EXTRACTION_ENABLED=true
CONSOLIDATION_ENABLED=true
