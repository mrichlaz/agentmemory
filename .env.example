# iii engine version pin
AGENTMEMORY_III_VERSION=0.11.2

# LLM provider for compression / summarization (pick one)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# GEMINI_API_KEY=replace-me
OPENROUTER_API_KEY=replace-me
# MINIMAX_API_KEY=replace-me

# Model settings
COMPRESSION_MODEL=anthropic/claude-sonnet-4-20250514

# Embeddings
EMBEDDING_PROVIDER=local
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSIONS=1536

# Auth
AGENTMEMORY_SECRET=change-me

# Feature flags
AGENTMEMORY_ALLOW_AGENT_SDK=false
AGENTMEMORY_AUTO_COMPRESS=true
AGENTMEMORY_SLOTS=true
AGENTMEMORY_REFLECT=true
AGENTMEMORY_INJECT_CONTEXT=true
GRAPH_EXTRACTION_ENABLED=true
CONSOLIDATION_ENABLED=true

# Ports
III_REST_PORT=3111
